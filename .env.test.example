# Environment Variables untuk Testing
# Copy file ini ke .env.local dan isi dengan credentials Anda

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (untuk client-side)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (untuk testing - JANGAN COMMIT!)
# Dapatkan dari: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
