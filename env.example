# ===============================
# Supabase Configuration
# ===============================
# REQUIRED: Your Supabase project URL
VITE_SUPABASE_URL=your_supabase_project_url_here

# REQUIRED: Your Supabase anonymous key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Example:
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===============================
# Vercel Deployment Configuration
# ===============================
# For Vercel deployment, set these environment variables in your Vercel project settings:
# 1. Go to your Vercel dashboard
# 2. Select your project
# 3. Go to Settings > Environment Variables
# 4. Add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
# 
# Production URLs should use HTTPS and have proper domains
# Example for production:
# VITE_SUPABASE_URL=https://your-production-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-production-anon-key

# ===============================
# Development & Migration (Optional)
# ===============================
# Database Migration (Optional - for development only)
FROM_PROJECT_ID=source_project_id
TO_PROJECT_ID=target_project_id
FROM_KEY=source_service_role_key
TO_KEY=target_service_role_key

# ===============================
# Local Development
# ===============================
# For local development, you can create a .env file with actual values
# Note: Never commit .env file to repository!
